<UserControl
  x:Class="UnRechnung.Views.InvoiceView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:conv="clr-namespace:UnRechnung.Converters"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:UnRechnung.Models"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="clr-namespace:UnRechnung.ViewModels"
  d:DesignHeight="540"
  d:DesignWidth="960"
  x:DataType="vm:InvoiceViewModel"
  mc:Ignorable="d">

  <UserControl.Resources>
    <conv:DecimalToCurrencyConverter x:Key="CurrencyConverter" />

    <StreamGeometry x:Key="grab_icon_1">M 0.375,4 A 0.375,0.375 0 0 0 0,4.375 0.375,0.375 0 0 0 0.375,4.75 h 5.8203125 a 0.375,0.375 0 0 0 0.375,-0.375 0.375,0.375 0 0 0 -0.375,-0.375 z m 0,-2 A 0.375,0.375 0 0 0 0,2.375 0.375,0.375 0 0 0 0.375,2.75 h 5.8203125 a 0.375,0.375 0 0 0 0.375,-0.375 0.375,0.375 0 0 0 -0.375,-0.375 z m 0,-2 A 0.375,0.375 0 0 0 0,0.375 0.375,0.375 0 0 0 0.375,0.75 h 5.8203125 a 0.375,0.375 0 0 0 0.375,-0.375 0.375,0.375 0 0 0 -0.375,-0.375 z</StreamGeometry>
    <StreamGeometry x:Key="grab_icon_2">M 14.25,10.5 A 0.75,0.75 0 0 1 13.5,11.25 0.75,0.75 0 0 1 12.75,10.5 0.75,0.75 0 0 1 13.5,9.75 0.75,0.75 0 0 1 14.25,10.5 Z m -5.5,0 A 0.75,0.75 0 0 1 8,11.25 0.75,0.75 0 0 1 7.25,10.5 0.75,0.75 0 0 1 8,9.75 0.75,0.75 0 0 1 8.75,10.5 Z m -5.5,0 A 0.75,0.75 0 0 1 2.5,11.25 0.75,0.75 0 0 1 1.75,10.5 0.75,0.75 0 0 1 2.5,9.75 0.75,0.75 0 0 1 3.25,10.5 Z m 11,-5 A 0.75,0.75 0 0 1 13.5,6.25 0.75,0.75 0 0 1 12.75,5.5 0.75,0.75 0 0 1 13.5,4.75 0.75,0.75 0 0 1 14.25,5.5 Z m -5.5,0 A 0.75,0.75 0 0 1 8,6.25 0.75,0.75 0 0 1 7.25,5.5 0.75,0.75 0 0 1 8,4.75 0.75,0.75 0 0 1 8.75,5.5 Z m -5.5,0 A 0.75,0.75 0 0 1 2.5,6.25 0.75,0.75 0 0 1 1.75,5.5 0.75,0.75 0 0 1 2.5,4.75 0.75,0.75 0 0 1 3.25,5.5 Z</StreamGeometry>
  </UserControl.Resources>

  <Design.DataContext>
    <vm:InvoiceViewModel />
  </Design.DataContext>

  <Grid
    Cursor="{Binding CurrentCursor}"
    IsEnabled="{Binding IsUiEnabled}"
    RowDefinitions="Auto,*,Auto">
    <TextBlock
      Grid.Row="0"
      Margin="13"
      FontSize="18"
      FontWeight="Bold"
      Text="Rechnung erstellen" />

    <ScrollViewer Grid.Row="1">
      <TabControl>
        <TabItem Header="Rechnung">
          <Grid RowDefinitions="Auto,Auto,Auto">
            <Expander
              Grid.Row="0"
              HorizontalAlignment="Stretch"
              Header="Kundenangaben"
              IsExpanded="True">
              <Grid ColumnDefinitions="*,*">
                <Grid
                  Grid.Column="0"
                  HorizontalAlignment="Stretch"
                  ColumnDefinitions="Auto,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                  <AutoCompleteBox
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="5"
                    FilterMode="Contains"
                    IsTextCompletionEnabled="True"
                    ItemsSource="{Binding CustomerSelection}"
                    MinimumPrefixLength="0"
                    SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                    Watermark="Kunde suchen">
                    <AutoCompleteBox.ItemTemplate>
                      <DataTemplate DataType="{x:Type local:Customer}">
                        <StackPanel Orientation="Vertical" Spacing="5">
                          <TextBlock Text="{Binding Name}" />
                          <StackPanel Orientation="Horizontal">
                            <TextBlock
                              FontSize="12"
                              Foreground="#c4c4c4"
                              Text="{Binding Representative}" />
                            <TextBlock
                              Margin="5,0,5,0"
                              FontSize="12"
                              Foreground="#c4c4c4"
                              Text="|" />
                            <TextBlock
                              FontSize="12"
                              Foreground="#c4c4c4"
                              Text="{Binding CustomerNumber}" />
                          </StackPanel>
                        </StackPanel>
                      </DataTemplate>
                    </AutoCompleteBox.ItemTemplate>
                  </AutoCompleteBox>
                  <TextBox
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="5"
                    Text="{Binding SelectedCustomer.Street}"
                    Watermark="Straße" />
                  <TextBox
                    Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Margin="5"
                    Text="{Binding SelectedCustomer.AddressComplement}"
                    Watermark="Adresszusatz (optional)" />
                  <TextBox
                    Grid.Row="3"
                    Grid.Column="0"
                    Width="100"
                    Margin="5"
                    Text="{Binding SelectedCustomer.PostalCode}"
                    Watermark="PLZ" />
                  <TextBox
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Text="{Binding SelectedCustomer.City}"
                    Watermark="Ort" />
                  <ComboBox
                    Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0">
                    <ComboBoxItem Content="Deutschland" />
                  </ComboBox>
                </Grid>
                <Grid
                  Grid.Column="1"
                  HorizontalAlignment="Stretch"
                  ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                  <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="5"
                    VerticalAlignment="Center"
                    FlowDirection="RightToLeft"
                    Text="Rechnungsnummer" />
                  <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="5"
                    IsReadOnly="True"
                    Text="{Binding InvoiceNumber}"
                    Watermark="automatisch" />
                  <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="5"
                    VerticalAlignment="Center"
                    FlowDirection="RightToLeft"
                    Text="Kundennummer" />
                  <TextBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"
                    IsReadOnly="True"
                    Text="{Binding SelectedCustomer.CustomerNumber}"
                    Watermark="z.B. 10001" />
                  <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="5"
                    VerticalAlignment="Center"
                    FlowDirection="RightToLeft"
                    Text="Datum" />
                  <CalendarDatePicker
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    SelectedDate="{Binding SelectedInvoiceDate}" />
                  <ComboBox
                    Grid.Row="3"
                    Grid.Column="0"
                    Margin="5"
                    HorizontalAlignment="Right"
                    SelectedIndex="0">
                    <ComboBoxItem Content="Lieferdatum" />
                    <ComboBoxItem Content="Leistungsdatum" />
                    <ComboBoxItem Content="Lieferzeitraum" />
                    <ComboBoxItem Content="Leistungszeitraum" />
                    <ComboBoxItem Content="Kein Lieferdatum anzeigen" />
                  </ComboBox>
                  <CalendarDatePicker
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    SelectedDate="{Binding SelectedInvoiceDeliveryDate}" />
                  <HyperlinkButton
                    Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Margin="5"
                    HorizontalAlignment="Right"
                    VerticalContentAlignment="Center"
                    Content="+ Kunde zur Datenbank hinzufügen"
                    FontSize="16"
                    Foreground="{DynamicResource ResourceKey=BasePurple}"
                    IsVisible="{Binding IsNewCustomer}" />
                </Grid>
              </Grid>
            </Expander>

            <Expander
              Grid.Row="1"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Header="Rechnungspositionen"
              IsExpanded="True">
              <Grid RowDefinitions="Auto,*">
                <Grid
                  Grid.Row="0"
                  Margin="0,0,0,0"
                  ColumnDefinitions="Auto,Auto,3*,*,*,*,*,*,*,Auto">
                  <Separator Grid.Column="0" Width="0" />
                  <TextBlock
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Right"
                    FontWeight="Bold"
                    Foreground="{DynamicResource ResourceKey=BasePurple}"
                    Text="Pos." />
                  <TextBlock
                    Grid.Column="2"
                    Margin="18,0,0,0"
                    FontWeight="Bold"
                    Foreground="{DynamicResource ResourceKey=BasePurple}"
                    Text="Produkt / Leistung" />
                  <TextBlock
                    Grid.Column="3"
                    Margin="0,0,11,0"
                    HorizontalAlignment="Right"
                    FontWeight="Bold"
                    Foreground="{DynamicResource ResourceKey=BasePurple}"
                    Text="Menge" />
                  <TextBlock
                    Grid.Column="4"
                    Margin="8,0,0,0"
                    FontWeight="Bold"
                    Foreground="{DynamicResource ResourceKey=BasePurple}"
                    Text="Einheit" />
                  <TextBlock
                    Grid.Column="5"
                    Margin="0,0,15,0"
                    HorizontalAlignment="Right"
                    FontWeight="Bold"
                    Foreground="{DynamicResource ResourceKey=BasePurple}"
                    Text="Preis" />
                  <TextBlock
                    Grid.Column="6"
                    Margin="0,0,19,0"
                    HorizontalAlignment="Right"
                    FontWeight="Bold"
                    Foreground="{DynamicResource ResourceKey=BasePurple}"
                    Text="Steuern" />
                  <TextBlock
                    Grid.Column="7"
                    Margin="0,0,24,0"
                    HorizontalAlignment="Right"
                    FontWeight="Bold"
                    Foreground="{DynamicResource ResourceKey=BasePurple}"
                    Text="Rabatt" />
                  <TextBlock
                    Grid.Column="8"
                    Margin="0,0,27,0"
                    HorizontalAlignment="Right"
                    FontWeight="Bold"
                    Foreground="{DynamicResource ResourceKey=BasePurple}"
                    Text="Gesamt" />
                  <Separator Grid.Column="9" Width="0" />
                </Grid>

                <ListBox
                  Name="InvoiceItemsListBox"
                  Grid.Row="1"
                  MaxHeight="350"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  IsTextSearchEnabled="True"
                  ItemsSource="{Binding CurrentInvoiceItems}"
                  SelectedIndex="{Binding SelectedTableItemIndex}"
                  SelectionChanged="ListBox_SelectionChanged">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="Margin" Value="0" />
                      <Setter Property="MinHeight" Value="0" />
                    </Style>
                  </ListBox.Styles>

                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border
                        Margin="2"
                        BorderBrush="#c4c4c4"
                        BorderThickness="0,1,0,0"
                        DragDrop.AllowDrop="True"
                        PointerPressed="InvoiceItem_PointerPressedAsync">
                        <Grid
                          ColumnDefinitions="Auto,Auto,3*,*,*,*,*,*,*,Auto"
                          DragDrop.AllowDrop="True"
                          RowDefinitions="Auto,Auto">
                          <PathIcon
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Cursor="SizeAll"
                            Data="{StaticResource grab_icon_1}"
                            Foreground="{DynamicResource ResourceKey=BasePurple}" />
                          <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            MinWidth="40"
                            Padding="10"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Text="{Binding Position}" />
                          <AutoCompleteBox
                            Grid.Row="0"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FilterMode="Contains"
                            IsTextCompletionEnabled="True"
                            ItemsSource="{Binding ((vm:InvoiceViewModel)DataContext).AllProducts, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            MinimumPrefixLength="1"
                            SelectedItem="{Binding Product}"
                            Text="{Binding Name, UpdateSourceTrigger=LostFocus}">
                            <AutoCompleteBox.Styles>
                              <Style Selector="AutoCompleteBox">
                                <Setter Property="Template">
                                  <ControlTemplate>
                                    <Grid Name="PART_LayoutRoot">
                                      <TextBox
                                        Name="PART_TextBox"
                                        Width="{TemplateBinding Width}"
                                        Margin="0"
                                        Padding="10"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CaretIndex="{TemplateBinding CaretIndex,
                                                                     Mode=TwoWay}"
                                        CornerRadius="{TemplateBinding CornerRadius}"
                                        DataValidationErrors.Errors="{TemplateBinding (DataValidationErrors.Errors)}"
                                        Foreground="{TemplateBinding Foreground}"
                                        InnerLeftContent="{TemplateBinding InnerLeftContent}"
                                        InnerRightContent="{TemplateBinding InnerRightContent}"
                                        MaxLength="{TemplateBinding MaxLength}"
                                        Watermark="{TemplateBinding Watermark}">
                                        <TextBox.Styles>
                                          <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                          </Style>
                                          <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                            <Setter Property="Background" Value="White" />
                                            <Setter Property="BorderThickness" Value="0" />
                                          </Style>
                                        </TextBox.Styles>
                                      </TextBox>
                                      <Popup
                                        Name="PART_Popup"
                                        MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        IsLightDismissEnabled="True"
                                        PlacementTarget="{TemplateBinding}"
                                        WindowManagerAddShadowHint="False">
                                        <Border
                                          Name="PART_SuggestionsContainer"
                                          Padding="{DynamicResource AutoCompleteListMargin}"
                                          Background="{DynamicResource AutoCompleteBoxSuggestionsListBackground}"
                                          BorderBrush="{DynamicResource AutoCompleteBoxSuggestionsListBorderBrush}"
                                          BorderThickness="{DynamicResource AutoCompleteListBorderThemeThickness}"
                                          CornerRadius="{DynamicResource OverlayCornerRadius}">
                                          <ListBox
                                            Name="PART_SelectingItemsControl"
                                            Margin="{DynamicResource AutoCompleteListPadding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ItemTemplate="{TemplateBinding ItemTemplate}" />
                                        </Border>
                                      </Popup>
                                    </Grid>
                                  </ControlTemplate>
                                </Setter>
                              </Style>
                            </AutoCompleteBox.Styles>

                            <AutoCompleteBox.ItemTemplate>
                              <DataTemplate DataType="{x:Type local:Product}">
                                <StackPanel Spacing="2">
                                  <TextBlock
                                    Margin="10,10,10,0"
                                    FontWeight="Bold"
                                    Text="{Binding Name}" />
                                  <TextBlock
                                    Margin="10,0,10,10"
                                    FontSize="12"
                                    Foreground="#c4c4c4"
                                    Text="{Binding Description}" />
                                </StackPanel>
                              </DataTemplate>
                            </AutoCompleteBox.ItemTemplate>
                          </AutoCompleteBox>
                          <TextBox
                            Grid.Row="0"
                            Grid.Column="3"
                            Padding="10"
                            HorizontalContentAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Text="{Binding Quantity}">
                            <TextBox.Styles>
                              <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                            </TextBox.Styles>
                          </TextBox>
                          <TextBox
                            Grid.Row="0"
                            Grid.Column="4"
                            Padding="10"
                            Background="Transparent"
                            BorderThickness="0"
                            Text="{Binding Unit}">
                            <TextBox.Styles>
                              <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                            </TextBox.Styles>
                          </TextBox>
                          <TextBox
                            Grid.Row="0"
                            Grid.Column="5"
                            Padding="10"
                            HorizontalContentAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Text="{Binding UnitPrice, StringFormat={}{0:C}, Converter={StaticResource CurrencyConverter}}">
                            <TextBox.Styles>
                              <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                            </TextBox.Styles>
                          </TextBox>
                          <TextBox
                            Grid.Row="0"
                            Grid.Column="6"
                            Padding="10"
                            HorizontalContentAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Text="{Binding Taxes, StringFormat={}{0:N2} %}">
                            <TextBox.Styles>
                              <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                            </TextBox.Styles>
                          </TextBox>
                          <TextBox
                            Grid.Row="0"
                            Grid.Column="7"
                            Padding="10"
                            HorizontalContentAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Text="{Binding Discount, StringFormat={}{0:N2} %}">
                            <TextBox.Styles>
                              <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                            </TextBox.Styles>
                          </TextBox>
                          <TextBox
                            Grid.Row="0"
                            Grid.Column="8"
                            Padding="10"
                            HorizontalContentAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Text="{Binding Total, StringFormat={}{0:C}, Converter={StaticResource CurrencyConverter}}">
                            <TextBox.Styles>
                              <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                            </TextBox.Styles>
                          </TextBox>
                          <Button
                            Grid.Row="0"
                            Grid.Column="9"
                            Margin="10,0"
                            Classes="delete"
                            Command="{Binding ((vm:InvoiceViewModel)DataContext).RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                            CommandParameter="{Binding}" />

                          <TextBox
                            Grid.Row="1"
                            Grid.Column="2"
                            Grid.ColumnSpan="7"
                            Padding="10"
                            Background="Transparent"
                            BorderThickness="0"
                            IsVisible="{Binding HasDescription}"
                            Text="{Binding Description}"
                            TextWrapping="WrapWithOverflow"
                            Watermark="Beschreibung">
                            <TextBox.Styles>
                              <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                              <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                              </Style>
                            </TextBox.Styles>
                          </TextBox>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Border
                  Name="GhostItem"
                  Width="1000"
                  Height="35"
                  Margin="2"
                  BorderBrush="#c4c4c4"
                  IsVisible="False"
                  Opacity="0.8">
                  <Grid
                    ColumnDefinitions="Auto,Auto,3*,*,*,*,*,*,*,Auto"
                    DragDrop.AllowDrop="True"
                    RowDefinitions="Auto,Auto">
                    <PathIcon
                      Grid.Row="0"
                      Grid.Column="0"
                      Margin="0,0,10,0"
                      VerticalAlignment="Center"
                      Cursor="SizeAll"
                      Data="{StaticResource grab_icon_1}"
                      Foreground="{DynamicResource ResourceKey=BasePurple}" />
                    <TextBlock
                      Grid.Row="0"
                      Grid.Column="1"
                      MinWidth="40"
                      Padding="10"
                      HorizontalAlignment="Right"
                      Background="Transparent"
                      Text="{Binding DraggingInvoiceItem.Position}" />
                    <TextBlock
                      Grid.Row="0"
                      Grid.Column="2"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      Text="{Binding DraggingInvoiceItem.Name}" />
                    <TextBlock
                      Grid.Row="0"
                      Grid.Column="3"
                      Padding="10"
                      HorizontalAlignment="Right"
                      Background="Transparent"
                      Text="{Binding DraggingInvoiceItem.Quantity}" />
                    <TextBlock
                      Grid.Row="0"
                      Grid.Column="4"
                      Padding="10"
                      Background="Transparent"
                      Text="{Binding DraggingInvoiceItem.Unit}" />
                    <TextBlock
                      Grid.Row="0"
                      Grid.Column="5"
                      Padding="10"
                      HorizontalAlignment="Right"
                      Background="Transparent"
                      Text="{Binding DraggingInvoiceItem.UnitPrice, StringFormat={}{0:C}}" />
                    <TextBlock
                      Grid.Row="0"
                      Grid.Column="6"
                      Padding="10"
                      HorizontalAlignment="Right"
                      Background="Transparent"
                      Text="{Binding DraggingInvoiceItem.Taxes, StringFormat={}{0:N2} %}" />
                    <TextBlock
                      Grid.Row="0"
                      Grid.Column="7"
                      Padding="10"
                      HorizontalAlignment="Right"
                      Background="Transparent"
                      Text="{Binding DraggingInvoiceItem.Discount, StringFormat={}{0:N2} %}" />
                    <TextBlock
                      Grid.Row="0"
                      Grid.Column="8"
                      Padding="10"
                      HorizontalAlignment="Right"
                      Background="Transparent"
                      Text="{Binding DraggingInvoiceItem.Total, StringFormat={}{0:C}}" />
                    <Button
                      Grid.Row="0"
                      Grid.Column="9"
                      Margin="10,0"
                      Classes="delete" />
                  </Grid>
                </Border>
              </Grid>
            </Expander>
            <Grid Grid.Row="2" ColumnDefinitions="6*,3*">
              <Button
                Grid.Column="0"
                Width="100"
                Margin="15,0,0,0"
                VerticalAlignment="Top"
                HorizontalContentAlignment="Center"
                BorderBrush="#c4c4c4"
                BorderThickness="1"
                Command="{Binding AddItemCommand}"
                Content="➕" />
              <Border
                Grid.Column="1"
                Margin="0,0,15,0"
                BorderBrush="#c4c4c4"
                BorderThickness="1"
                CornerRadius="3">
                <StackPanel Orientation="Vertical">
                  <Grid ColumnDefinitions="*,*">
                    <TextBlock
                      Grid.Column="0"
                      Padding="10,5,0,0"
                      FontSize="16"
                      Text="Zwischensumme netto" />
                    <TextBlock
                      Grid.Column="1"
                      Padding="0,5,51,0"
                      HorizontalAlignment="Right"
                      FontSize="16"
                      Text="{Binding SubTotal, StringFormat={}{0:C}}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*">
                    <TextBlock
                      Grid.Column="0"
                      Padding="10,5,0,0"
                      FontSize="16"
                      Text="Gesamt netto" />
                    <TextBlock
                      Grid.Column="1"
                      Padding="0,5,51,0"
                      HorizontalAlignment="Right"
                      FontSize="16"
                      Text="{Binding NetTotal, StringFormat={}{0:C}}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,*">
                    <TextBlock
                      Grid.Column="0"
                      Padding="10,5,0,0"
                      FontSize="16"
                      Text="USt 19 %" />
                    <TextBlock
                      Grid.Column="1"
                      Padding="0,5,51,5"
                      HorizontalAlignment="Right"
                      FontSize="16"
                      Text="{Binding SalesTax, StringFormat={}{0:C}}" />
                  </Grid>
                  <Border BorderBrush="#c4c4c4" BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="*,*">
                      <TextBlock
                        Grid.Column="0"
                        Padding="10,5,0,5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Gesamtbetrag" />
                      <TextBlock
                        Grid.Column="1"
                        Padding="0,0,51,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="{Binding EndTotal, StringFormat={}{0:C}}" />
                    </Grid>
                  </Border>
                </StackPanel>
              </Border>
            </Grid>
          </Grid>
        </TabItem>

        <TabItem Header="PDF Preview">
          <Border
            Width="600"
            Height="800"
            BorderBrush="{DynamicResource ResourceKey=BasePurple}"
            BorderThickness="1">
            <Image Source="{Binding PdfPreviewImage}" Stretch="Uniform" />
          </Border>
        </TabItem>
      </TabControl>
    </ScrollViewer>
    <Border
      Grid.Row="2"
      Margin="30"
      Padding="0,0,0,5"
      HorizontalAlignment="Right"
      BorderBrush="{DynamicResource ResourceKey=BasePurple}"
      BorderThickness="0,0,0,2">
      <Button
        HorizontalAlignment="Right"
        HorizontalContentAlignment="Center"
        BorderBrush="#c4c4c4"
        BorderThickness="1"
        Command="{Binding CompleteInvoiceCommand}"
        Content="Fertigstellen" />
    </Border>
  </Grid>
</UserControl>
