<Application
  x:Class="UnRechnung.App"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:UnRechnung"
  RequestedThemeVariant="Light">
  <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
        <!--  Light Theme  -->
        <ColorPaletteResources
          x:Key="Light"
          Accent="#ffa951ff"
          AltHigh="White"
          AltLow="White"
          AltMedium="White"
          AltMediumHigh="White"
          AltMediumLow="White"
          BaseHigh="Black"
          BaseLow="White"
          BaseMedium="#ffb1b1b1"
          BaseMediumHigh="#ffa951ff"
          BaseMediumLow="#ff979797"
          ChromeAltLow="#ff7d7d7d"
          ChromeBlackHigh="Black"
          ChromeBlackLow="White"
          ChromeBlackMedium="#ff7d7d7d"
          ChromeBlackMediumLow="#ffb1b1b1"
          ChromeDisabledHigh="White"
          ChromeDisabledLow="#ffb1b1b1"
          ChromeGray="#ff979797"
          ChromeHigh="White"
          ChromeLow="White"
          ChromeMedium="White"
          ChromeMediumLow="White"
          ChromeWhite="White"
          ListLow="#fff0f0f0"
          ListMedium="White"
          RegionColor="White" />

        <!--  Dark Theme  -->
        <ColorPaletteResources
          x:Key="Dark"
          Accent="#ffa951ff"
          AltHigh="#ff2b2b2b"
          AltLow="Black"
          AltMedium="Black"
          AltMediumHigh="#ff323232"
          AltMediumLow="#ff323232"
          BaseHigh="White"
          BaseLow="#ff323232"
          BaseMedium="#ff999999"
          BaseMediumHigh="#ffa951ff"
          BaseMediumLow="#ff666666"
          ChromeAltLow="#ffb3b3b3"
          ChromeBlackHigh="Black"
          ChromeBlackLow="#ffb3b3b3"
          ChromeBlackMedium="Black"
          ChromeBlackMediumLow="Black"
          ChromeDisabledHigh="#ff323232"
          ChromeDisabledLow="#ff999999"
          ChromeGray="#ff7f7f7f"
          ChromeHigh="#ff7f7f7f"
          ChromeLow="#ff151515"
          ChromeMedium="#ff1c1c1c"
          ChromeMediumLow="#ff2b2b2b"
          ChromeWhite="White"
          ListLow="#ff1c1c1c"
          ListMedium="#ff323232"
          RegionColor="#ff323232" />
      </FluentTheme.Palettes>
    </FluentTheme>
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

    <!--  DataGrid TextBlock font styling  -->
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Arial" />
    </Style>

    <!--  DataGrid styling  -->
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Foreground" Value="{DynamicResource ResourceKey=BasePurple}" />
      <Setter Property="FontSize" Value="16" />
    </Style>
    <Style Selector="DataGridColumnHeader.numeric">
      <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>

    <!--  Purple Button styling  -->
    <Style Selector="Button.purple">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{DynamicResource ResourceKey=BasePurple}" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.purple:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ResourceKey=FocusPurple}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.purple:focus /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ResourceKey=FocusPurple}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.purple:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="LightGray" />
    </Style>

    <!--  Edit Button styling  -->
    <Style Selector="Button.edit">
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="Transparent" CornerRadius="0">
            <PathIcon Data="{DynamicResource edit_icon}">
              <PathIcon.Styles>
                <Style Selector="Button:pointerover PathIcon">
                  <Style.Animations>
                    <Animation Duration="0:0:0.2">
                      <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                      </KeyFrame>
                      <KeyFrame Cue="25%">
                        <Setter Property="RotateTransform.Angle" Value="-20" />
                      </KeyFrame>
                      <KeyFrame Cue="50%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                      </KeyFrame>
                      <KeyFrame Cue="75%">
                        <Setter Property="RotateTransform.Angle" Value="20" />
                      </KeyFrame>
                      <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                      </KeyFrame>
                    </Animation>
                  </Style.Animations>
                </Style>
              </PathIcon.Styles>
            </PathIcon>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <!--  Delete Button styling  -->
    <Style Selector="Button.delete">
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="Transparent" CornerRadius="0">
            <PathIcon Data="{DynamicResource delete_icon}">
              <PathIcon.Styles>
                <Style Selector="Button PathIcon">
                  <Setter Property="Foreground" Value="Red" />
                </Style>

                <Style Selector="Button:pointerover PathIcon">
                  <Style.Animations>
                    <Animation Duration="0:0:0.2">
                      <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                      </KeyFrame>
                      <KeyFrame Cue="25%">
                        <Setter Property="RotateTransform.Angle" Value="-20" />
                      </KeyFrame>
                      <KeyFrame Cue="50%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                      </KeyFrame>
                      <KeyFrame Cue="75%">
                        <Setter Property="RotateTransform.Angle" Value="20" />
                      </KeyFrame>
                      <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                      </KeyFrame>
                    </Animation>
                  </Style.Animations>
                </Style>
              </PathIcon.Styles>
            </PathIcon>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <!--  Dashboard Frames  -->
    <Style Selector="Border.dashboardFrame">
      <Setter Property="Padding" Value="13" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="-1 -1 15 LightGray, 2 2 #ffa951ff" />
      <Setter Property="CornerRadius" Value="5" />
    </Style>
  </Application.Styles>

  <Application.Resources>
    <!--  Base Colors  -->
    <SolidColorBrush x:Key="BasePurple">#FFA951FF</SolidColorBrush>
    <SolidColorBrush x:Key="FocusPurple">#FF7132AF</SolidColorBrush>

    <!--  Notification Colors  -->
    <SolidColorBrush x:Key="InfoBackground">#E8F3FA</SolidColorBrush>
    <SolidColorBrush x:Key="InfoForeground">#2B6CB0</SolidColorBrush>
    <SolidColorBrush x:Key="WarningBackground">#FFF9E0</SolidColorBrush>
    <SolidColorBrush x:Key="WarningForeground">#EBBD28</SolidColorBrush>
    <SolidColorBrush x:Key="ErrorBackground">#FDE8E8</SolidColorBrush>
    <SolidColorBrush x:Key="ErrorForeground">#C53030</SolidColorBrush>
    <SolidColorBrush x:Key="SuccessBackground">#E6F6EC</SolidColorBrush>
    <SolidColorBrush x:Key="SuccessForeground">#2D7A46</SolidColorBrush>

    <!--  SVG Icons  -->
